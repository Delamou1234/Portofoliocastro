# Configuration pour le Portfolio DELAMOU Samaké
# Créez une copie de ce fichier nommée ".env" et remplissez vos vraies valeurs

# ============================================
# GEMINI API - Configuration du Chatbot
# ============================================
# Pour activer le chatbot intelligent, obtenez une clé API gratuite sur:
# 1. Allez sur https://makersuite.google.com/app/apikey
# 2. Connectez-vous avec votre compte Google
# 3. Cliquez sur "Create API key"
# 4. Copiez la clé générée ci-dessous

GEMINI_API_KEY=votre_cle_api_gemini_ici
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_API_MODEL=gemini-2.5-flash-preview-05-20

# ============================================
# Configuration Email (Gmail)
# ============================================
# Votre adresse email Gmail
EMAIL_HOST_USER=samakedelamou858@gmail.com

# Mot de passe d'application Gmail (PAS votre mot de passe Gmail habituel)
# Pour générer un mot de passe d'application :
# 1. Activez la validation en deux étapes sur votre compte Google
# 2. Allez sur https://myaccount.google.com/apppasswords
# 3. Sélectionnez "Autre" et donnez le nom "Django Portfolio"
# 4. Copiez le mot de passe de 16 caractères SANS ESPACES
EMAIL_HOST_PASSWORD=votre_mot_de_passe_application_16_caracteres

# Email où recevoir les messages du formulaire de contact
ADMIN_EMAIL=samakedelamou858@gmail.com

# ============================================
# INSTRUCTIONS IMPORTANTES
# ============================================
# 1. Copiez ce fichier et renommez-le en ".env"
# 2. Remplacez les valeurs par vos vraies informations
# 3. Ne partagez JAMAIS ce fichier .env (il est exclu de Git)
# 4. Redémarrez le serveur Django après modification
