# ==============================================================================
# CONFIGURATION DE DÉPLOIEMENT PROFESSIONNELLE (DJANGO)
# ==============================================================================
# Copiez ce fichier vers ".env" et remplissez les valeurs.
# Ne commitez JAMAIS le fichier ".env" sur Git.

# --- PARAMÈTRES DJANGO ---
# Générez une clé robuste pour la prod : python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=votre_cle_secrete_django_ici
DJANGO_DEBUG=True
# Séparez les hôtes par des virgules (ex: localhost,votre-domaine.com)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Séparez les origins par des virgules pour CSRF (ex: https://votre-domaine.com)
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- BASE DE DONNÉES ---
# Par défaut utilise SQLite. Pour une DB de production, décommentez et remplissez.
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=portfolio_db
# DB_USER=postgres
# DB_PASSWORD=votre_password
# DB_HOST=localhost
# DB_PORT=5432

# --- CONFIGURATION EMAIL (SMTP GMAIL) ---
EMAIL_HOST_USER=samakedelamou858@gmail.com
EMAIL_HOST_PASSWORD=votre_mot_de_passe_d_application_gmail
ADMIN_EMAIL=samakedelamou858@gmail.com

# --- API GEMINI (AI ASSISTANT) ---
GEMINI_API_KEY=votre_cle_api_gemini
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_API_MODEL=gemini-2.5-flash-lite

# --- SÉCURITÉ SUPPLÉMENTAIRE (OPTIONNEL POUR PROD) ---
# SECURE_SSL_REDIRECT=False
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False
